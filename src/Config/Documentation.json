{
  "openapi": "3.1.0",
  "info": {
    "title": "API de Gestion de Bibliothèque",
    "version": "1.0.1",
    "description": "Documentation JSON de l'API."
  },
  "servers": [
    { "url": "http://localhost:3000/" }
  ],
  "paths": {
    "/api/bibliotheque/inscription": {
      "post": {
        "tags": ["Authentification"],
        "summary": "Inscription",
        "responses": { "201": { "description": "Créé" } }
      }
    },
    "/api/bibliotheque/cle": {
      "post": {
        "tags": ["Authentification"],
        "summary": "Obtenir clé",
        "parameters": [{ "in": "query", "name": "nouvelle", "schema": { "type": "boolean" } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/livres": {
      "get": { "tags": ["Livres"], "summary": "Liste", "responses": { "200": { "description": "OK" } } },
      "post": { "tags": ["Livres"], "summary": "Ajout", "responses": { "201": { "description": "OK" } } }
    },
    "/api/livres/{id}/statut": {
      "patch": { "tags": ["Livres"], "summary": "Statut", "responses": { "200": { "description": "OK" } } }
    },
    "/api/prets": {
      "post": { "tags": ["Prêts"], "summary": "Nouveau prêt", "responses": { "201": { "description": "OK" } } }
    },
    "/api/prets/{id}": {
      "patch": { "tags": ["Prêts"], "summary": "Terminer prêt", "responses": { "200": { "description": "OK" } } },
      "delete": { "tags": ["Prêts"], "summary": "Supprimer", "responses": { "204": { "description": "OK" } } }
    }
  }
}